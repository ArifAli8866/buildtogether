# Copy this file to .env.local and fill in your own values.
# You get these from your Supabase project: Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Used for building absolute redirect URLs (OAuth callback).
# Locally this is http://localhost:3000
# In Vercel, set this to your deployed URL, e.g. https://cofound.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
